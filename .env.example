VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# Email суперадминов через запятую (полный доступ, включая персонализацию)
VITE_SUPERADMIN_EMAILS=
VITE_OPENAI_API_KEY=

# YandexGPT (серверные ключи — не попадают в браузер, только для локального dev)
# Те же ключи, что в bringhome: Yandex Cloud → IAM → API-ключи; каталог → ID папки
YANDEX_API_KEY=your_copied_api_key_here
YANDEX_FOLDER_ID=b1gopp0dfgdbi9fv8c00

# URL прокси разбора ТЗ. Локально по умолчанию /api/yandex/parse (Vite middleware).
# Прод: Yandex Cloud Functions после .\scripts\deploy-yandex-parse.ps1
# VITE_YANDEX_PARSE_URL=https://functions.yandexcloud.net/<function-id>
VITE_YANDEX_PARSE_URL=

rules_version = '2';

service cloud.firestore {
  function isSignedIn() {
    return request.auth != null;
  }

  function isValidEstimate() {
    let data = request.resource.data;
    return data.keys().hasAll([
        'id',
        'projectName',
        'clientName',
        'description',
        'sections',
        'rates',
        'createdAt',
        'updatedAt',
        'createdByUid',
        'createdByName',
      ])
      && data.id is string
      && data.id.size() > 0
      && data.id.size() <= 128
      && data.projectName is string
      && data.projectName.size() > 0
      && data.projectName.size() <= 300
      && data.clientName is string
      && data.clientName.size() <= 300
      && data.description is string
      && data.description.size() <= 5000
      && data.sections is list
      && data.rates is map
      && data.createdAt is string
      && data.updatedAt is string
      && data.createdByUid is string
      && data.createdByName is string;
  }

  function isAuthor() {
    return isSignedIn() && resource.data.createdByUid == request.auth.uid;
  }

  function isValidUserProfile() {
    let data = request.resource.data;
    return data.keys().hasAll(['uid', 'email', 'displayName', 'role'])
      && data.uid is string
      && data.email is string
      && data.displayName is string
      && data.role in ['user', 'superadmin']
      && (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 200))
      && (!('position' in data) || (data.position is string && data.position.size() <= 200));
  }

  function userRoleUnchanged() {
    return !('role' in resource.data)
      || request.resource.data.role == resource.data.role;
  }

  function isArchiveStatusUpdate() {
    let affected = request.resource.data.diff(resource.data).affectedKeys();
    return affected.hasOnly(['isArchived', 'updatedAt'])
      || affected.hasOnly(['isArchived', 'updatedAt', 'createdByUid', 'createdByName']);
  }

  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidUserProfile()
        && request.resource.data.role == 'user';
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUserProfile()
        && userRoleUnchanged();
    }

    // Общая база организации: чтение и редактирование для всех авторизованных участников.
    match /estimates/{estimateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isValidEstimate()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isSignedIn() && (
        isValidEstimate()
        || (isArchiveStatusUpdate() && request.resource.data.isArchived is bool)
      );
      allow delete: if isSignedIn() && (
        resource.data.get('isArchived', false) == true
        || resource.data.get('isDraft', false) == true
        || resource.data.projectName.matches('.*\\(Копия\\).*$')
      );
    }

    // Строгий вариант — только автор редактирует свои сметы:
    // allow update: if isSignedIn() && isValidEstimate() && isAuthor();

    function isValidCompany() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'id',
          'name',
          'inn',
          'kpp',
          'ogrn',
          'legalAddress',
          'bankAccount',
          'bik',
          'bankName',
          'director',
          'directorBasis',
          'createdAt',
          'updatedAt',
        ])
        && data.id is string
        && data.id.size() > 0
        && data.id.size() <= 128
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 300
        && data.inn is string && data.inn.size() <= 20
        && data.kpp is string && data.kpp.size() <= 20
        && data.ogrn is string && data.ogrn.size() <= 20
        && data.legalAddress is string && data.legalAddress.size() <= 500
        && data.bankAccount is string && data.bankAccount.size() <= 40
        && data.bik is string && data.bik.size() <= 20
        && data.bankName is string && data.bankName.size() <= 300
        && data.director is string && data.director.size() <= 200
        && data.directorBasis is string && data.directorBasis.size() <= 200
        && data.createdAt is string
        && data.updatedAt is string
        && (!('logoDataUrl' in data)
          || data.logoDataUrl == null
          || (data.logoDataUrl is string && data.logoDataUrl.size() <= 900000));
    }

    match /companies/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidCompany();
      allow delete: if isSignedIn();
    }

    match /contract_templates/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    function isValidPresentationSlidesSettings() {
      let data = request.resource.data;
      return (!('aboutImageDataUrl' in data)
          || data.aboutImageDataUrl == null
          || (data.aboutImageDataUrl is string && data.aboutImageDataUrl.size() <= 900000))
        && (!('recognitionImageDataUrl' in data)
          || data.recognitionImageDataUrl == null
          || (data.recognitionImageDataUrl is string && data.recognitionImageDataUrl.size() <= 900000))
        && (!('qrImageDataUrl' in data)
          || data.qrImageDataUrl == null
          || (data.qrImageDataUrl is string && data.qrImageDataUrl.size() <= 900000))
        && (!('updatedAt' in data) || data.updatedAt is string)
        && (!('updatedByUid' in data) || data.updatedByUid is string)
        && (!('updatedByName' in data) || data.updatedByName is string);
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && docId == 'presentation_slides'
        && isValidPresentationSlidesSettings();
      allow delete: if false;
    }
  }
}

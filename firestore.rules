rules_version = '2';

service cloud.firestore {
  function isSignedIn() {
    return request.auth != null;
  }

  function isValidEstimate() {
    let data = request.resource.data;
    return data.keys().hasAll([
        'id',
        'projectName',
        'clientName',
        'description',
        'sections',
        'rates',
        'createdAt',
        'updatedAt',
        'createdByUid',
        'createdByName',
      ])
      && data.id is string
      && data.id.size() > 0
      && data.id.size() <= 128
      && data.projectName is string
      && data.projectName.size() > 0
      && data.projectName.size() <= 300
      && data.clientName is string
      && data.clientName.size() <= 300
      && data.description is string
      && data.description.size() <= 5000
      && data.sections is list
      && data.rates is map
      && data.createdAt is string
      && data.updatedAt is string
      && data.createdByUid is string
      && data.createdByName is string;
  }

  function isAuthor() {
    return isSignedIn() && resource.data.createdByUid == request.auth.uid;
  }

  function isValidUserProfile() {
    let data = request.resource.data;
    return data.keys().hasAll(['uid', 'email', 'displayName', 'role'])
      && data.uid is string
      && data.email is string
      && data.displayName is string
      && data.role in ['user', 'superadmin']
      && (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 200))
      && (!('position' in data) || (data.position is string && data.position.size() <= 200));
  }

  function userRoleUnchanged() {
    return !('role' in resource.data)
      || request.resource.data.role == resource.data.role;
  }

  function isArchiveStatusUpdate() {
    let affected = request.resource.data.diff(resource.data).affectedKeys();
    return affected.hasOnly(['isArchived', 'updatedAt'])
      || affected.hasOnly(['isArchived', 'updatedAt', 'createdByUid', 'createdByName']);
  }

  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidUserProfile()
        && request.resource.data.role == 'user';
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUserProfile()
        && userRoleUnchanged();
    }

    // Общая база организации: чтение и редактирование для всех авторизованных участников.
    match /estimates/{estimateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isValidEstimate()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isSignedIn() && (
        isValidEstimate()
        || (isArchiveStatusUpdate() && request.resource.data.isArchived is bool)
      );
      allow delete: if isSignedIn() && (
        resource.data.get('isArchived', false) == true
        || resource.data.get('isDraft', false) == true
        || resource.data.projectName.matches('.*\\(Копия\\).*$')
      );
    }

    // Строгий вариант — только автор редактирует свои сметы:
    // allow update: if isSignedIn() && isValidEstimate() && isAuthor();

    function isValidCompany() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'id',
          'name',
          'inn',
          'kpp',
          'ogrn',
          'legalAddress',
          'bankAccount',
          'bik',
          'bankName',
          'director',
          'directorBasis',
          'createdAt',
          'updatedAt',
        ])
        && data.id is string
        && data.id.size() > 0
        && data.id.size() <= 128
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 300
        && data.inn is string && data.inn.size() <= 20
        && data.kpp is string && data.kpp.size() <= 20
        && data.ogrn is string && data.ogrn.size() <= 20
        && data.legalAddress is string && data.legalAddress.size() <= 500
        && data.bankAccount is string && data.bankAccount.size() <= 40
        && data.bik is string && data.bik.size() <= 20
        && data.bankName is string && data.bankName.size() <= 300
        && data.director is string && data.director.size() <= 200
        && data.directorBasis is string && data.directorBasis.size() <= 200
        && data.createdAt is string
        && data.updatedAt is string
        && (!('logoDataUrl' in data)
          || data.logoDataUrl == null
          || (data.logoDataUrl is string && data.logoDataUrl.size() <= 900000));
    }

    match /companies/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidCompany();
      allow delete: if isSignedIn();
    }

    function isValidCatalogProduct() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'type', 'name', 'description', 'unit', 'createdAt', 'updatedAt'])
        && data.id is string
        && data.id.size() > 0
        && data.id.size() <= 128
        && data.type in ['software', 'service', 'hardware']
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 300
        && data.description is string
        && data.description.size() <= 2000
        && data.unit is string
        && data.unit.size() > 0
        && data.unit.size() <= 40
        && data.createdAt is string
        && data.updatedAt is string
        && (
          (data.type == 'software'
            && data.oneTimePrice is number
            && data.oneTimePrice >= 0
            && data.subscriptionPrice is number
            && data.subscriptionPrice >= 0)
          || (data.type in ['service', 'hardware']
            && data.price is number
            && data.price >= 0)
        );
    }

    match /products_directory/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidCatalogProduct();
      allow delete: if isSignedIn();
    }

    match /contract_templates/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    function isValidPresentationSlideContent(data) {
      return data is map
        && (!('title' in data) || (data.title is string && data.title.size() <= 300))
        && (!('badge' in data) || (data.badge is string && data.badge.size() <= 1000))
        && (!('badgeIcon' in data) || (data.badgeIcon is string && data.badgeIcon.size() <= 32))
        && (!('badgeColor' in data) || (data.badgeColor is string && data.badgeColor.size() <= 32))
        && (!('disclaimer' in data) || (data.disclaimer is string && data.disclaimer.size() <= 1000))
        && (!('subtitle' in data) || (data.subtitle is string && data.subtitle.size() <= 300))
        && (!('bulletsText' in data) || (data.bulletsText is string && data.bulletsText.size() <= 5000))
        && (!('body' in data) || (data.body is string && data.body.size() <= 5000))
        && (!('qrCaption' in data) || (data.qrCaption is string && data.qrCaption.size() <= 1000))
        && (!('qrBadgeColor' in data) || (data.qrBadgeColor is string && data.qrBadgeColor.size() <= 32))
        && (!('imageDataUrl' in data)
          || data.imageDataUrl == null
          || (data.imageDataUrl is string && data.imageDataUrl.size() <= 900000))
        && (!('qrImageDataUrl' in data)
          || data.qrImageDataUrl == null
          || (data.qrImageDataUrl is string && data.qrImageDataUrl.size() <= 900000));
    }

    function isValidPresentationSlidesSettings() {
      let data = request.resource.data;
      return (!('slides' in data) || (
          data.slides is map
          && (!('about' in data.slides) || isValidPresentationSlideContent(data.slides.about))
          && (!('recognition' in data.slides) || isValidPresentationSlideContent(data.slides.recognition))
          && (!('kiosk' in data.slides) || isValidPresentationSlideContent(data.slides.kiosk))
          && (!('customSlides' in data.slides)
            || (data.slides.customSlides is list && data.slides.customSlides.size() <= 30))
        ))
        && (!('aboutImageDataUrl' in data)
          || data.aboutImageDataUrl == null
          || (data.aboutImageDataUrl is string && data.aboutImageDataUrl.size() <= 900000))
        && (!('recognitionImageDataUrl' in data)
          || data.recognitionImageDataUrl == null
          || (data.recognitionImageDataUrl is string && data.recognitionImageDataUrl.size() <= 900000))
        && (!('qrImageDataUrl' in data)
          || data.qrImageDataUrl == null
          || (data.qrImageDataUrl is string && data.qrImageDataUrl.size() <= 900000))
        && (!('updatedAt' in data) || data.updatedAt is string)
        && (!('updatedByUid' in data) || data.updatedByUid == null || data.updatedByUid is string)
        && (!('updatedByName' in data) || data.updatedByName == null || data.updatedByName is string);
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && docId == 'presentation_slides'
        && isValidPresentationSlidesSettings();
      allow delete: if false;
    }
  }
}
